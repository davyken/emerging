# ── Frontend — Xtream Codes (IPTV / VOD) ──────────────────────────────────────
VITE_XTREAM_HOST=http://your-xtream-host.com
VITE_XTREAM_USERNAME=your_username
VITE_XTREAM_PASSWORD=your_password

# ── Frontend — TMDB (trailer search) ──────────────────────────────────────────
VITE_TMDB_API_KEY=your_tmdb_api_key

# ── Backend — MongoDB & JWT ────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/emergingstream
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
PORT=5000

# ── Jellyfin (VOD) ───────────────────────────────────────────────────────────
# VITE_JELLYFIN_URL=https://jellyfin.example.com
# VITE_API_KEY=your_jellyfin_api_key_here
# VITE_JELLYFIN_USER_ID=your_jellyfin_user_id_here
VITE_JELLYFIN_URL=https://jellyfin.emergingstream.com
